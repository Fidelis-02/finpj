# Configuração do Cloudflare R2 (ou AWS S3 compatível)
# Para uploads grandes (>4.5MB) funcionarem na Vercel
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=seu_access_key
R2_SECRET_ACCESS_KEY=seu_secret_key
R2_BUCKET_NAME=finpj-documents
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Outras configurações já existentes
JWT_SECRET=seu_jwt_secret
MONGODB_URI=sua_uri_mongodb
GROQ_API_KEY=sua_chave_groq
STRIPE_SECRET_KEY=sua_chave_stripe
STRIPE_WEBHOOK_SECRET=seu_webhook_secret
